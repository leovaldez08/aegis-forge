# ─────────────────────────────────────────────────────
# Aegis Node — Environment Variables
# Copy this file to .env and fill in the values
# ─────────────────────────────────────────────────────

# ── PostgreSQL ──────────────────────────────────────
DATABASE_URL=postgresql://aegis:aegis_secret@localhost:5432/aegis_node
POSTGRES_USER=aegis
POSTGRES_PASSWORD=aegis_secret
POSTGRES_DB=aegis_node

# ── MQTT Broker ─────────────────────────────────────
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_TOPIC_PREFIX=aegis/telemetry

# ── AI Microservice ─────────────────────────────────
AI_SERVICE_URL=http://localhost:8000
GEMINI_API_KEY=your_gemini_api_key_here

# ── Backend Server ──────────────────────────────────
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# ── JWT Auth ────────────────────────────────────────
JWT_SECRET=change_me_to_a_random_64_char_string

# ── Twilio (optional, for SMS) ──────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
