{
  "name": "@aegis/backend",
  "version": "1.0.0",
  "private": true,
  "description": "Aegis Node — Fastify backend for IoT telemetry ingestion and anomaly detection",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "seed": "tsx src/db/seed.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.0",
    "@fastify/jwt": "^9.0.0",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.39.3",
    "fastify": "^5.2.1",
    "mqtt": "^5.10.4",
    "pino-pretty": "^13.1.3",
    "postgres": "^3.4.5",
    "socket.io": "^4.8.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "drizzle-kit": "^0.30.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
